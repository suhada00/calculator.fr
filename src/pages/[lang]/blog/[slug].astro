---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/ui/Card.astro';
import categories from '../../../data/categories.json';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../../lib/i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const parts = post.id.split('/');
    const lang = post.data.lang;
    const slug = parts[parts.length - 1].replace(/\.md$/, '');
    return {
      params: { lang, slug },
      props: { post }
    };
  });
}

const { post } = Astro.props;
const { lang, slug } = Astro.params;
const locale = lang || 'en';
const t = useTranslations(locale);

const { Content } = await render(post);

// Generate alternate URLs
const allPosts = await getCollection('blog');
const otherLang = locale === 'en' ? 'fr' : 'en';
const altPost = allPosts.find(
  (p) => p.data.lang === otherLang && p.data.relatedCalculator === post.data.relatedCalculator
);

const alternateUrls: Record<string, string> = {};
if (altPost) {
  const altSlug = altPost.id.split('/').pop().replace(/\.md$/, '');
  alternateUrls[locale] = `/${locale}/blog/${slug}/`;
  alternateUrls[otherLang] = `/${otherLang}/blog/${altSlug}/`;
} else {
  alternateUrls[locale] = `/${locale}/blog/${slug}/`;
  alternateUrls[otherLang] = `/${otherLang}/blog/`;
}

// Fetch calculator information for the related CTA
const files = import.meta.glob('../../../data/calculators/**/*.json', { eager: true });
const allCalculatorsMap: Record<string, any> = {};
for (const path in files) {
  const file = (files[path] as any).default || files[path];
  allCalculatorsMap[file.slug] = file;
}

const relCalc = allCalculatorsMap[post.data.relatedCalculator];
let relatedCalculatorInfo = null;
if (relCalc) {
  const relTrans = relCalc.translations[locale];
  const relToolsSlug = locale === 'fr' ? 'calculateurs' : 'calculators';
  const relCatSlug = (categories as any)[relCalc.category].translations[locale].slug;
  relatedCalculatorInfo = {
    title: relTrans.title,
    path: `/${locale}/${relToolsSlug}/${relCatSlug}/${relTrans.slug}/`
  };
}

const breadcrumbs = [
  { name: locale === 'fr' ? 'Accueil' : 'Home', item: `/${locale}/` },
  { name: 'Blog', item: `/${locale}/blog/` },
  { name: post.data.title, item: Astro.url.pathname }
];

const articleMetadata = {
  title: post.data.title,
  description: post.data.description,
  pubDate: post.data.pubDate,
  author: post.data.author,
  url: Astro.url.pathname
};
---

<BaseLayout
  title={`${post.data.title} — EuroCalc`}
  description={post.data.description}
  locale={locale}
  alternateUrls={alternateUrls}
  breadcrumbs={breadcrumbs}
  article={articleMetadata}
>
  <div class="max-w-4xl mx-auto py-8 px-4 md:py-12">
    <article class="bg-surface border border-border rounded-xl p-6 md:p-10 shadow-sm">
      <!-- Category & Date -->
      <div class="flex items-center gap-2 text-xs font-semibold text-primary-500 mb-4">
        <span class="bg-primary-500/10 px-2.5 py-1 rounded-full uppercase tracking-wider">
          {post.data.category}
        </span>
        <span class="text-text-muted">•</span>
        <span class="text-text-muted font-normal">
          {post.data.pubDate.toLocaleDateString(locale === 'fr' ? 'fr-FR' : 'en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          })}
        </span>
        <span class="text-text-muted">•</span>
        <span class="text-text-muted font-normal">{locale === 'fr' ? `Par ${post.data.author}` : `By ${post.data.author}`}</span>
      </div>

      <!-- Title -->
      <h1 class="text-3xl md:text-5xl font-black text-text-heading tracking-tight mb-8 leading-tight">
        {post.data.title}
      </h1>

      <!-- Main Markdown Content -->
      <div class="prose prose-neutral dark:prose-invert max-w-none mb-10 leading-relaxed text-text-body space-y-6">
        <Content />
      </div>

      <!-- Related Calculator CTA -->
      {relatedCalculatorInfo && (
        <div class="mt-8 pt-8 border-t border-border">
          <Card class="bg-primary-500/5 border-primary-500/20 p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="space-y-2 text-center md:text-left">
              <h3 class="text-xl font-extrabold text-text-heading">
                {locale === 'fr' ? 'Besoin de faire une simulation ?' : 'Ready to Calculate?'}
              </h3>
              <p class="text-sm text-text-muted">
                {locale === 'fr' 
                  ? `Utilisez notre ${relatedCalculatorInfo.title} en ligne pour simuler instantanément vos résultats.`
                  : `Use our free, online ${relatedCalculatorInfo.title} to estimate your numbers immediately.`
                }
              </p>
            </div>
            <a 
              href={relatedCalculatorInfo.path}
              class="w-full md:w-auto inline-flex items-center justify-center px-6 h-12 rounded-lg font-bold text-white bg-primary-500 hover:bg-primary-600 transition-colors shadow-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2"
            >
              {locale === 'fr' ? 'Ouvrir le simulateur' : 'Open Calculator'}
            </a>
          </Card>
        </div>
      )}
    </article>
  </div>
</BaseLayout>
