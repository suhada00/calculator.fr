---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Card from '../../../components/ui/Card.astro';
import categories from '../../../data/categories.json';
import { useTranslations } from '../../../lib/i18n';

export async function getStaticPaths() {
  return [
    { params: { lang: 'en', toolsSlug: 'calculators' }, props: { locale: 'en' } },
    { params: { lang: 'fr', toolsSlug: 'calculateurs' }, props: { locale: 'fr' } }
  ];
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const toolsSlug = locale === 'fr' ? 'calculateurs' : 'calculators';
const alternateToolsSlug = locale === 'en' ? 'calculateurs' : 'calculators';
const alternateLang = locale === 'en' ? 'fr' : 'en';

const alternateUrls = {
  en: `/en/calculators/`,
  fr: `/fr/calculateurs/`
};

// Fetch and filter all published calculators
const files = import.meta.glob('../../../data/calculators/**/*.json', { eager: true });
const allCalculators = [];

for (const path in files) {
  const file = (files[path] as any).default || files[path];
  if (file.status === 'published') {
    allCalculators.push(file);
  }
}

// Group calculators by category
const groupedCategories = Object.keys(categories)
  .map((catKey) => {
    const catConfig = (categories as any)[catKey];
    const catCalculators = allCalculators.filter((c) => c.category === catKey);
    
    return {
      key: catKey,
      name: catConfig.translations[locale].name,
      slug: catConfig.translations[locale].slug,
      calculators: catCalculators.map((c) => {
        const trans = c.translations[locale];
        return {
          title: trans.title,
          description: trans.metaDescription,
          path: `/${locale}/${toolsSlug}/${catConfig.translations[locale].slug}/${trans.slug}/`
        };
      })
    };
  });

const breadcrumbs = [
  { name: locale === 'fr' ? 'Accueil' : 'Home', item: `/${locale}/` },
  { name: t('calculators'), item: Astro.url.pathname }
];
---

<BaseLayout
  title={`${t('calculators')} — ${t('brandName')}`}
  description={t('homeSubtitle')}
  locale={locale}
  alternateUrls={alternateUrls}
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Hero Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h1 class="text-display font-extrabold text-text-heading tracking-tight mb-4">
        {t('calculators')}
      </h1>
      <p class="text-body-lg text-text-muted">
        {locale === 'fr' 
          ? 'Explorez notre suite complète de simulateurs financiers, de santé et d\'outils du quotidien.'
          : 'Browse our full suite of precise financial, health, and everyday utility calculators.'
        }
      </p>
    </div>

    <!-- Category Tabs Selector -->
    <div class="flex overflow-x-auto scrollbar-none gap-2.5 mb-12 border-b border-border/60 pb-6 max-w-4xl mx-auto px-4 -mx-4 md:mx-auto md:px-0 md:justify-center md:flex-wrap">
      <button
        data-tab="all"
        class="px-5 py-2.5 rounded-full text-sm font-semibold transition-all border border-border cursor-pointer bg-primary-500 text-white border-primary-500 shadow-sm flex-shrink-0"
      >
        {locale === 'fr' ? 'Tous' : 'All'}
      </button>
      {groupedCategories.map((group) => (
        <button
          data-tab={group.slug}
          class="px-5 py-2.5 rounded-full text-sm font-semibold transition-all border border-border bg-surface text-text-base hover:border-primary-500 hover:text-primary-500 cursor-pointer flex-shrink-0"
        >
          {group.name}
        </button>
      ))}
    </div>

    <!-- Category Sections -->
    <div class="space-y-16">
      {groupedCategories.map((group) => (
        <section id={group.slug} class="scroll-mt-20 category-section">
          <div class="flex items-center gap-3 mb-6">
            <h2 class="text-h2 font-extrabold text-text-heading">
              {group.name}
            </h2>
            <span class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-primary-50 text-primary-500 border border-primary-500/10">
              {group.calculators.length}
            </span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {group.calculators.length === 0 ? (
              <Card class="p-8 border-dashed border-2 border-border bg-surface-alt flex flex-col items-center justify-center text-center col-span-full py-12">
                <span class="text-3xl mb-3">🚀</span>
                <h3 class="text-base font-bold text-text-heading mb-1">
                  {locale === 'fr' ? 'Bientôt disponible' : 'Coming Soon'}
                </h3>
                <p class="text-xs text-text-muted max-w-sm">
                  {locale === 'fr' 
                    ? `Les simulateurs de la catégorie "${group.name}" sont en cours de développement.`
                    : `Calculators in the "${group.name}" category are currently under development.`
                  }
                </p>
              </Card>
            ) : (
              group.calculators.map((calc) => (
                <a href={calc.path} class="group block">
                  <Card class="p-6 h-full flex flex-col justify-between hover:border-primary-500 hover:shadow-md transition-all duration-200">
                    <div class="space-y-2">
                      <h3 class="text-h3 font-bold text-text-heading group-hover:text-primary-500 transition-colors">
                        {calc.title}
                      </h3>
                      <p class="text-sm text-text-muted leading-relaxed line-clamp-3">
                        {calc.description}
                      </p>
                    </div>
                    <div class="mt-4 pt-4 border-t border-border/50 flex items-center gap-1 text-sm font-semibold text-primary-500 group-hover:text-primary-600">
                      <span>{locale === 'fr' ? 'Utiliser le calculateur' : 'Open Calculator'}</span>
                      <svg class="w-4 h-4 transform group-hover:translate-x-0.5 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </Card>
                </a>
              ))
            )}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('[data-tab]');
    const sections = document.querySelectorAll('.category-section');

    function showTab(tabId: string) {
      // Update tab button styles
      tabs.forEach(tab => {
        if (tab.getAttribute('data-tab') === tabId) {
          tab.classList.remove('bg-surface', 'text-text-base', 'border-border');
          tab.classList.add('bg-primary-500', 'text-white', 'border-primary-500', 'shadow-sm');
        } else {
          tab.classList.remove('bg-primary-500', 'text-white', 'border-primary-500', 'shadow-sm');
          tab.classList.add('bg-surface', 'text-text-base', 'border-border');
        }
      });

      // Show/hide sections
      sections.forEach(section => {
        const secId = section.getAttribute('id');
        if (tabId === 'all' || secId === tabId) {
          section.classList.remove('hidden');
        } else {
          section.classList.add('hidden');
        }
      });
    }

    // Add click listeners
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const tabId = tab.getAttribute('data-tab') || 'all';
        showTab(tabId);
        // Update URL hash without scrolling
        history.pushState(null, '', `#${tabId}`);
      });
    });

    // Check URL hash on load
    const hash = window.location.hash.replace('#', '');
    if (hash) {
      const match = Array.from(tabs).some(tab => tab.getAttribute('data-tab') === hash);
      if (match) {
        // Delay slightly to let page initialization complete
        setTimeout(() => showTab(hash), 50);
      } else {
        showTab('all');
      }
    } else {
      showTab('all');
    }
  });
</script>
